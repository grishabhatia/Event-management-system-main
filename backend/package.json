{
  "name": "eventone-backend",
  "version": "1.0.0",
  "description": "Backend API for eventone",
  "main": "index.js",
  "type": "module",

  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "seed": "node src/seed.js",
    "test-cloudinary": "node test-upload.js",
    "test": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand"
  },

  "keywords": [
    "events",
    "gssoc",
    "open-source"
  ],

  "author": "anubhavxdev",
  "license": "MIT",
  "type": "module",

  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-writer": "^1.6.0",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.24.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "validator": "^13.15.35"
  },

  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "mongodb-memory-server": "^10.4.3",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },

  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/src/__tests__/setup.js"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/src/__tests__/setup.js"
    ]
  }
}